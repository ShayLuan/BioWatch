# BioWatch environment variables — copy to .env for local dev
# Railway injects PORT automatically; set the rest in Railway's Variables tab.

# Comma-separated CORS origins (dev only — not needed when frontend is served by the backend)
CORS_ORIGINS=http://localhost:5173,http://localhost:4173

# URL of the optional ML inference service (leave blank to use the built-in AMRRiskEngine)
ML_ENDPOINT=http://localhost:8001/predict
